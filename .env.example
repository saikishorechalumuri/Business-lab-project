# Public/internal access
# Set to true locally if you want to use the demo OTP login at /login.
# Do not enable this for a public Vercel launch unless you intentionally want demo access open.
ENABLE_DEMO_LOGIN=true

# Used to read waitlist submissions through GET /api/waitlist.
# Send it as the x-admin-token header.
WAITLIST_ADMIN_TOKEN=replace-with-secure-random-token

# Supabase waitlist storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional live AI agent generation.
# Keep this server-side only. Never expose it as NEXT_PUBLIC.
# Server-only secret. Never commit the real value and never prefix with NEXT_PUBLIC.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
